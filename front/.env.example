# Endpoint REST que devuelve los reclamos procesados.
# Esperado: GET ${VITE_API_URL}/reclamos -> Array<Reclamo>
# Ejemplo: https://abc123.execute-api.us-east-1.amazonaws.com/dev
VITE_API_URL=

# Endpoint que devuelve una URL prefirmada para subir el CSV a S3.
# Esperado: POST ${VITE_PRESIGN_URL} body { filename, contentType }
#   -> { uploadUrl: string, key: string }
VITE_PRESIGN_URL=

# Solo referencial; el bucket real lo resuelve el backend.
VITE_BUCKET_NAME=reclamos-ingest-dev

# Cuando es "true", el front simula subidas y respuestas con datos mock.
# Útil para desarrollar la UI sin esperar a que el backend esté listo.
VITE_DEMO_MODE=true
